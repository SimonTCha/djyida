<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DJ YIDA — Official</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Barlow+Condensed:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --neon: #00FFD1;
    --neon2: #FF2D78;
    --neon3: #B400FF;
    --bg: #050507;
    --bg2: #0A0A0F;
    --bg3: #0F0F18;
    --text: #E8E8F0;
    --muted: #5A5A7A;
    --card: #0D0D16;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Barlow Condensed', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  .cursor {
    width: 12px; height: 12px;
    background: var(--neon);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, background 0.2s;
    mix-blend-mode: screen;
  }
  .cursor-ring {
    width: 36px; height: 36px;
    border: 1px solid var(--neon);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: width 0.3s, height 0.3s, border-color 0.3s;
    opacity: 0.6;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9997;
    opacity: 0.4;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 48px;
    background: linear-gradient(to bottom, rgba(5,5,7,0.95) 0%, transparent 100%);
    backdrop-filter: blur(4px);
    transition: background 0.3s, border-bottom 0.3s;
  }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.15em; color: var(--neon); text-shadow: 0 0 20px var(--neon), 0 0 60px rgba(0,255,209,0.3); text-decoration: none; }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a { font-family: 'Space Mono', monospace; font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; position: relative; }
  .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 1px; background: var(--neon); transform: scaleX(0); transition: transform 0.25s; }
  .nav-links a:hover { color: var(--neon); }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-book { font-family: 'Space Mono', monospace; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bg); background: var(--neon); border: none; padding: 10px 22px; cursor: none; font-weight: 700; transition: box-shadow 0.25s, transform 0.2s; text-decoration: none; }
  .nav-book:hover { box-shadow: 0 0 24px var(--neon), 0 0 60px rgba(0,255,209,0.4); transform: translateY(-1px); }

  /* HERO */
  #hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 0 48px 80px; position: relative; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 70% at 70% 40%, rgba(180,0,255,0.12) 0%, transparent 60%), radial-gradient(ellipse 40% 50% at 20% 80%, rgba(0,255,209,0.07) 0%, transparent 50%), var(--bg); }
  .scanlines { position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,209,0.012) 2px, rgba(0,255,209,0.012) 4px); pointer-events: none; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(0,255,209,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,209,0.04) 1px, transparent 1px); background-size: 60px 60px; transform: perspective(800px) rotateX(60deg) translateY(30%) scale(2.5); transform-origin: bottom center; opacity: 0.6; }
  .orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: pulse 6s ease-in-out infinite alternate; }
  .orb1 { width: 500px; height: 500px; top: -100px; right: -100px; background: rgba(180,0,255,0.18); }
  .orb2 { width: 300px; height: 300px; bottom: 100px; left: 5%; background: rgba(0,255,209,0.12); animation-delay: 2s; }
  .orb3 { width: 200px; height: 200px; top: 30%; left: 40%; background: rgba(255,45,120,0.1); animation-delay: 4s; }
  @keyframes pulse { 0%{opacity:.6;transform:scale(1)} 100%{opacity:1;transform:scale(1.15)} }

  .hero-content { position: relative; z-index: 2; max-width: 900px; }
  .hero-tag { font-family: 'Space Mono', monospace; font-size: 0.72rem; letter-spacing: 0.3em; color: var(--neon); text-transform: uppercase; margin-bottom: 16px; opacity: 0; animation: fadeUp 0.8s 0.3s forwards; }
  .hero-tag span { color: var(--muted); }
  .hero-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(6rem, 18vw, 16rem); line-height: 0.88; letter-spacing: 0.02em; color: var(--text); opacity: 0; animation: fadeUp 0.8s 0.5s forwards; }
  .hero-title .glitch { position: relative; display: inline-block; color: var(--neon); text-shadow: 0 0 30px rgba(0,255,209,0.6); }
  .hero-title .glitch::before, .hero-title .glitch::after { content: attr(data-text); position: absolute; top: 0; left: 0; }
  .hero-title .glitch::before { color: var(--neon2); clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%); transform: translateX(-3px); animation: glitch1 4s infinite; }
  .hero-title .glitch::after { color: var(--neon3); clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%); transform: translateX(3px); animation: glitch2 4s infinite; }
  @keyframes glitch1 { 0%,90%,100%{transform:translateX(-3px);opacity:0} 92%{transform:translateX(-6px) skewX(-5deg);opacity:.8} 94%{transform:translateX(4px);opacity:0} 96%{transform:translateX(-3px);opacity:.6} }
  @keyframes glitch2 { 0%,88%,100%{transform:translateX(3px);opacity:0} 90%{transform:translateX(8px) skewX(3deg);opacity:.7} 93%{transform:translateX(-4px);opacity:0} 95%{transform:translateX(3px);opacity:.5} }

  .hero-sub { font-size: 1.4rem; font-weight: 300; letter-spacing: 0.25em; color: var(--muted); text-transform: uppercase; margin-top: 12px; margin-bottom: 32px; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
  .hero-sub strong { color: var(--neon2); font-weight: 600; }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s 0.9s forwards; }

  /* Social icons in hero */
  .hero-socials { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s 1.1s forwards; }
  .hero-social-link { width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; transition: border-color 0.2s, color 0.2s, box-shadow 0.2s, transform 0.2s; }
  .hero-social-link:hover { border-color: var(--neon); color: var(--neon); box-shadow: 0 0 16px rgba(0,255,209,0.25); transform: translateY(-3px); }
  .hero-social-link svg { width: 17px; height: 17px; }

  .btn-primary { font-family: 'Space Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--bg); background: var(--neon); border: none; padding: 16px 36px; cursor: none; font-weight: 700; transition: box-shadow 0.25s, transform 0.2s; text-decoration: none; display: inline-block; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .btn-primary:hover { box-shadow: 0 0 30px var(--neon), 0 0 80px rgba(0,255,209,0.3); transform: translateY(-2px); }
  .btn-outline { font-family: 'Space Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--neon2); background: transparent; border: 1px solid var(--neon2); padding: 16px 36px; cursor: none; transition: box-shadow 0.25s, background 0.25s, color 0.25s, transform 0.2s; text-decoration: none; display: inline-block; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .btn-outline:hover { background: var(--neon2); color: var(--bg); box-shadow: 0 0 30px var(--neon2), 0 0 80px rgba(255,45,120,0.3); transform: translateY(-2px); }

  .scroll-hint { position: absolute; bottom: 32px; right: 48px; font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.2em; color: var(--muted); display: flex; align-items: center; gap: 12px; opacity: 0; animation: fadeUp 1s 1.3s forwards; }
  .scroll-line { width: 40px; height: 1px; background: var(--muted); position: relative; overflow: hidden; }
  .scroll-line::after { content: ''; position: absolute; left: -100%; top: 0; width: 100%; height: 100%; background: var(--neon); animation: scrollAnim 2s 1.5s infinite; }
  @keyframes scrollAnim { 0%{left:-100%} 100%{left:100%} }
  @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

  /* TICKER */
  .ticker-wrap { background: var(--neon); padding: 10px 0; overflow: hidden; }
  .ticker-track { display: flex; white-space: nowrap; animation: ticker 35s linear infinite; }
  .ticker-item { font-family: 'Bebas Neue', sans-serif; font-size: 0.9rem; letter-spacing: 0.2em; color: var(--bg); padding: 0 32px; }
  .ticker-sep { color: rgba(5,5,7,0.3); }
  @keyframes ticker { from{transform:translateX(0)} to{transform:translateX(-50%)} }

  /* SECTIONS */
  section { padding: 120px 48px; }
  .section-label { font-family: 'Space Mono', monospace; font-size: 0.68rem; letter-spacing: 0.35em; color: var(--neon); text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 16px; }
  .section-label::before { content: ''; width: 32px; height: 1px; background: var(--neon); }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 7vw, 6rem); line-height: 1; letter-spacing: 0.04em; margin-bottom: 60px; }

  /* ABOUT */
  #about { background: var(--bg2); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; max-width: 1200px; margin: 0 auto; }
  .about-visual { position: relative; aspect-ratio: 3/4; max-height: 560px; }
  .about-img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--bg3) 0%, rgba(180,0,255,0.15) 100%); border: 1px solid rgba(0,255,209,0.15); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; color: var(--muted); font-family: 'Space Mono', monospace; font-size: 0.75rem; letter-spacing: 0.1em; position: relative; overflow: hidden; }
  .about-img-placeholder::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,255,209,0.02) 10px, rgba(0,255,209,0.02) 20px); }
  .about-corner { position: absolute; width: 24px; height: 24px; border-color: var(--neon); border-style: solid; border-width: 0; }
  .about-corner.tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
  .about-corner.tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
  .about-corner.bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
  .about-corner.br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }
  .about-stat-bar { position: absolute; bottom: 24px; left: 24px; right: 24px; background: rgba(5,5,7,0.85); border: 1px solid rgba(0,255,209,0.2); padding: 16px 20px; display: flex; gap: 32px; backdrop-filter: blur(8px); }
  .stat-item { text-align: center; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--neon); line-height: 1; }
  .stat-label { font-family: 'Space Mono', monospace; font-size: 0.6rem; color: var(--muted); letter-spacing: 0.1em; margin-top: 4px; }
  .about-text p { font-size: 1.15rem; font-weight: 300; line-height: 1.8; color: rgba(232,232,240,0.75); margin-bottom: 20px; }
  .about-text p strong { color: var(--neon); font-weight: 600; }
  .about-tags { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 32px; }
  .tag { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; padding: 6px 14px; border: 1px solid rgba(0,255,209,0.25); color: var(--neon); text-transform: uppercase; }

  /* EVENTS */
  #events { background: var(--bg); }
  .events-inner { max-width: 1000px; margin: 0 auto; }
  .event-card { display: grid; grid-template-columns: 100px 1fr auto; gap: 32px; align-items: center; padding: 28px 32px; border: 1px solid rgba(255,255,255,0.05); border-left: 2px solid transparent; background: var(--card); margin-bottom: 2px; transition: border-color 0.25s, background 0.25s, transform 0.25s; cursor: none; position: relative; overflow: hidden; }
  .event-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,255,209,0.04) 0%, transparent 50%); opacity: 0; transition: opacity 0.3s; }
  .event-card:hover { border-left-color: var(--neon); background: rgba(0,255,209,0.03); transform: translateX(4px); }
  .event-card:hover::before { opacity: 1; }
  .event-card.past { opacity: 0.45; }
  .event-card.featured { border-left-color: var(--neon2); border-top: 1px solid rgba(255,45,120,0.2); }
  .event-card.featured::before { background: linear-gradient(90deg, rgba(255,45,120,0.05) 0%, transparent 50%); opacity: 1; }
  .event-date { text-align: center; border-right: 1px solid rgba(255,255,255,0.06); padding-right: 32px; }
  .event-day { font-family: 'Bebas Neue', sans-serif; font-size: 2.8rem; line-height: 1; color: var(--neon); }
  .event-card.featured .event-day { color: var(--neon2); }
  .event-month { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; color: var(--muted); text-transform: uppercase; margin-top: 2px; }
  .event-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 0.05em; color: var(--text); margin-bottom: 6px; }
  .event-meta { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted); display: flex; gap: 20px; flex-wrap: wrap; }
  .event-actions { display: flex; gap: 10px; align-items: center; }
  .event-badge { font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; padding: 5px 12px; border: 1px solid; text-transform: uppercase; }
  .badge-sold { border-color: var(--muted); color: var(--muted); }
  .badge-hot { border-color: var(--neon2); color: var(--neon2); animation: blink 2s infinite; }
  .badge-free { border-color: var(--neon); color: var(--neon); }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }
  .event-btn { font-family: 'Space Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 10px 20px; background: transparent; border: 1px solid var(--neon); color: var(--neon); cursor: none; transition: background 0.2s, color 0.2s, box-shadow 0.2s; text-decoration: none; display: inline-block; white-space: nowrap; }
  .event-btn:hover { background: var(--neon); color: var(--bg); box-shadow: 0 0 20px rgba(0,255,209,0.4); }
  .events-more { text-align: center; margin-top: 48px; }

  /* GALLERY */
  #highlights { background: var(--bg3); }
  .highlights-inner { max-width: 1200px; margin: 0 auto; }
  .gallery-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 280px 280px; gap: 4px; }
  .gallery-item { background: var(--card); border: 1px solid rgba(255,255,255,0.04); position: relative; overflow: hidden; cursor: none; }
  .gallery-item:first-child { grid-row: 1 / 3; }
  .gallery-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 12px; transition: transform 0.5s; position: relative; overflow: hidden; }
  .gallery-item:hover .gallery-placeholder { transform: scale(1.04); }
  .gallery-placeholder::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(5,5,7,0.85) 100%); }
  .gallery-item:nth-child(1) .gallery-placeholder { background: linear-gradient(135deg, #0a0015 0%, #1a0030 50%, #0a0015 100%); }
  .gallery-item:nth-child(2) .gallery-placeholder { background: linear-gradient(135deg, #00150d 0%, #00281a 100%); }
  .gallery-item:nth-child(3) .gallery-placeholder { background: linear-gradient(135deg, #150010 0%, #2a0020 100%); }
  .gallery-item:nth-child(4) .gallery-placeholder { background: linear-gradient(135deg, #100010 0%, #1f0025 100%); }
  .gallery-item:nth-child(5) .gallery-placeholder { background: linear-gradient(135deg, #001215 0%, #00252a 100%); }
  .gallery-icon { width: 48px; height: 48px; border: 1px solid rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.2); position: relative; z-index: 1; }
  .gallery-label { font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.15em; color: rgba(255,255,255,0.2); text-transform: uppercase; position: relative; z-index: 1; }
  .gallery-overlay { position: absolute; inset: 0; background: rgba(0,255,209,0.08); opacity: 0; transition: opacity 0.3s; z-index: 2; border: 1px solid rgba(0,255,209,0.2); }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 24px; z-index: 3; transform: translateY(10px); opacity: 0; transition: transform 0.3s, opacity 0.3s; }
  .gallery-item:hover .gallery-caption { transform: translateY(0); opacity: 1; }
  .gallery-caption-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 0.05em; color: var(--text); }
  .gallery-caption-sub { font-family: 'Space Mono', monospace; font-size: 0.6rem; color: var(--neon); letter-spacing: 0.1em; margin-top: 4px; }
  .gallery-upload-note { text-align: center; margin-top: 20px; font-family: 'Space Mono', monospace; font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; }

  /* MEDIA */
  #media { background: var(--bg2); }
  .media-inner { max-width: 1200px; margin: 0 auto; }
  .media-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; flex-wrap: wrap; gap: 20px; }
  .media-badge { font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.15em; padding: 5px 14px; text-transform: uppercase; font-weight: 700; }
  .yt-badge { background: #FF0000; color: white; }
  .sc-badge { background: #FF5500; color: white; }
  .media-label { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .media-label-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; letter-spacing: 0.05em; color: var(--text); }
  .yt-feature { position: relative; width: 100%; padding-bottom: 56.25%; background: var(--card); border: 1px solid rgba(0,255,209,0.12); overflow: hidden; margin-bottom: 48px; }
  .yt-feature iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
  .media-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .sc-embed-wrap { background: var(--card); border: 1px solid rgba(0,255,209,0.12); overflow: hidden; position: relative; }
  .sc-embed-wrap::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--neon), var(--neon3), var(--neon2)); z-index: 1; }
  .sc-embed-wrap iframe { display: block; width: 100%; border: none; }
  .yt-channel-card { background: var(--card); border: 1px solid rgba(0,255,209,0.12); padding: 40px 32px; display: flex; flex-direction: column; gap: 20px; align-items: center; justify-content: center; text-align: center; height: 100%; min-height: 340px; }

  /* SOCIAL */
  #social { background: var(--bg3); }
  .social-inner { max-width: 1200px; margin: 0 auto; }
  .social-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px; flex-wrap: wrap; gap: 20px; }
  .platform-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin-bottom: 2px; }
  .platform-card { background: var(--card); border: 1px solid rgba(255,255,255,0.05); padding: 36px 28px; display: flex; flex-direction: column; gap: 16px; text-decoration: none; cursor: none; transition: border-color 0.25s, transform 0.25s, background 0.25s; position: relative; overflow: hidden; }
  .platform-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; transform: scaleX(0); transition: transform 0.3s; transform-origin: left; }
  .platform-card:hover { transform: translateY(-4px); }
  .platform-card.tiktok::after { background: linear-gradient(90deg, #00f2ea, #ff0050); }
  .platform-card.tiktok:hover { border-color: rgba(0,242,234,0.3); background: rgba(0,242,234,0.03); }
  .platform-card.instagram::after { background: linear-gradient(90deg, #f09433, #dc2743, #bc1888); }
  .platform-card.instagram:hover { border-color: rgba(220,39,67,0.3); background: rgba(220,39,67,0.03); }
  .platform-card.soundcloud::after { background: #FF5500; }
  .platform-card.soundcloud:hover { border-color: rgba(255,85,0,0.3); background: rgba(255,85,0,0.03); }
  .platform-card.threads::after { background: var(--text); }
  .platform-card.threads:hover { border-color: rgba(232,232,240,0.2); background: rgba(232,232,240,0.02); }
  .platform-card:hover::after { transform: scaleX(1); }
  .platform-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; }
  .platform-icon svg { width: 28px; height: 28px; }
  .platform-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 0.08em; color: var(--text); }
  .platform-handle { font-family: 'Space Mono', monospace; font-size: 0.65rem; color: var(--muted); letter-spacing: 0.08em; }
  .platform-arrow { font-size: 1.2rem; color: var(--muted); margin-top: auto; transition: color 0.2s, transform 0.2s; }
  .platform-card:hover .platform-arrow { color: var(--neon); transform: translateX(4px); }

  /* Douyin row */
  .douyin-row { background: var(--card); border: 1px solid rgba(0,255,209,0.1); padding: 20px 28px; display: flex; align-items: center; gap: 20px; }
  .douyin-badge { font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; padding: 5px 12px; border: 1px solid rgba(0,255,209,0.3); color: var(--neon); text-transform: uppercase; white-space: nowrap; }
  .douyin-text { font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--muted); letter-spacing: 0.08em; }
  .douyin-text a { color: var(--neon); text-decoration: none; }
  .douyin-text a:hover { text-decoration: underline; }

  /* CONTACT */
  #contact { background: var(--bg); }
  .contact-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .contact-info p { font-size: 1.1rem; font-weight: 300; line-height: 1.8; color: rgba(232,232,240,0.65); margin-bottom: 32px; }
  .contact-details { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .contact-details li { display: flex; gap: 16px; align-items: center; font-family: 'Space Mono', monospace; font-size: 0.75rem; letter-spacing: 0.08em; color: var(--muted); }
  .contact-details li strong { color: var(--neon); min-width: 80px; }
  .contact-details a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .contact-details a:hover { color: var(--neon); }
  .booking-form { display: flex; flex-direction: column; gap: 16px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-field { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-family: 'Space Mono', monospace; font-size: 0.62rem; letter-spacing: 0.15em; color: var(--muted); text-transform: uppercase; }
  .form-input, .form-select, .form-textarea { background: var(--card); border: 1px solid rgba(255,255,255,0.08); color: var(--text); padding: 14px 16px; font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; letter-spacing: 0.05em; outline: none; transition: border-color 0.2s, box-shadow 0.2s; cursor: none; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--neon); box-shadow: 0 0 0 1px rgba(0,255,209,0.2); }
  .form-input::placeholder, .form-textarea::placeholder { color: var(--muted); }
  .form-select option { background: var(--bg3); }
  .form-textarea { resize: vertical; min-height: 120px; }
  .form-submit { font-family: 'Space Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--bg); background: var(--neon); border: none; padding: 18px 32px; cursor: none; font-weight: 700; transition: box-shadow 0.25s, transform 0.2s; margin-top: 8px; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .form-submit:hover { box-shadow: 0 0 30px var(--neon), 0 0 80px rgba(0,255,209,0.25); transform: translateY(-2px); }

  /* FOOTER */
  footer { padding: 48px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 0.1em; color: var(--neon); text-shadow: 0 0 20px rgba(0,255,209,0.4); }
  .footer-copy { font-family: 'Space Mono', monospace; font-size: 0.62rem; color: var(--muted); letter-spacing: 0.1em; }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a { font-family: 'Space Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--neon); }

  /* MOBILE */
  @media (max-width: 768px) {
    nav { padding: 16px 20px; }
    .nav-links { display: none; }
    #hero { padding: 0 20px 60px; }
    section { padding: 80px 20px; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-visual { max-height: 400px; }
    .event-card { grid-template-columns: 70px 1fr; gap: 16px; }
    .event-actions { display: none; }
    .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .gallery-item:first-child { grid-row: auto; grid-column: 1 / -1; }
    .platform-grid { grid-template-columns: 1fr 1fr; }
    .media-grid { grid-template-columns: 1fr; }
    .contact-inner { grid-template-columns: 1fr; }
    footer { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav id="mainNav">
  <a href="#hero" class="nav-logo">YIDA</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#events">Events</a></li>
    <li><a href="#highlights">Gallery</a></li>
    <li><a href="#media">Media</a></li>
    <li><a href="#social">Socials</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="nav-book">Book Now</a>
</nav>

