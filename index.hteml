<!-- CONTACT -->
<section id="contact">
  <div class="contact-inner">
    <div class="contact-info">
      <div class="section-label">Booking</div>
      <h2 class="section-title">Let's Make<br>It Happen</h2>
      <p>Ready to bring DJ Yida to your event? Fill out the form and we'll get back to you within 24 hours. Available for clubs, festivals, corporate events, and private parties.</p>
      <ul class="contact-details">
        <li><strong>Email</strong> <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="50343a2939343110373d31393c7e333f3d">[email&#160;protected]</a></li>
        <li><strong>TikTok</strong> <a href="https://www.tiktok.com/@djyida" target="_blank">@djyida</a></li>
        <li><strong>Instagram</strong> <a href="https://www.instagram.com/djyida/" target="_blank">@djyida</a></li>
        <li><strong>Threads</strong> <a href="https://www.threads.com/@djyida" target="_blank">@djyida</a></li>
        <li><strong>SoundCloud</strong> <a href="https://soundcloud.com/djyida" target="_blank">soundcloud.com/djyida</a></li>
        <li><strong>YouTube</strong> <a href="https://www.youtube.com/@djyida" target="_blank">@djyida</a></li>
      </ul>
    </div>
    <div class="booking-form">
      <div class="form-row">
        <div class="form-field"><label class="form-label">First Name</label><input class="form-input" type="text" placeholder="John"></div>
        <div class="form-field"><label class="form-label">Last Name</label><input class="form-input" type="text" placeholder="Doe"></div>
      </div>
      <div class="form-field"><label class="form-label">Email</label><input class="form-input" type="email" placeholder="you@email.com"></div>
      <div class="form-row">
        <div class="form-field">
          <label class="form-label">Event Type</label>
          <select class="form-select">
            <option value="">Select...</option>
            <option>Club Night</option><option>Festival</option>
            <option>Private Party</option><option>Corporate Event</option>
            <option>Birthday / Celebration</option><option>Other</option>
          </select>
        </div>
        <div class="form-field"><label class="form-label">Event Date</label><input class="form-input" type="date"></div>
      </div>
      <div class="form-field"><label class="form-label">Venue / Location</label><input class="form-input" type="text" placeholder="Club Nova, New York"></div>
      <div class="form-field"><label class="form-label">Message</label><textarea class="form-textarea" placeholder="Tell us about your event — expected crowd size, vibe, set length..."></textarea></div>
      <button class="form-submit" onclick="handleSubmit(this)">Send Booking Request →</button>
    </div>
  </div>
</section>

