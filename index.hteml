    <span class="ticker-item">SOUNDCLOUD.COM/DJYIDA <span class="ticker-sep">✦</span></span>
  </div>
</div>

<!-- ABOUT -->
<section id="about">
  <div class="about-grid">
    <div class="about-visual">
      <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;object-position:center top;">
      <div class="about-corner tl"></div><div class="about-corner tr"></div>
      <div class="about-corner bl"></div><div class="about-corner br"></div>
      <div class="about-stat-bar">
        <div class="stat-item"><div class="stat-num">100K+</div><div class="stat-label">Followers</div></div>
        <div class="stat-item"><div class="stat-num">Global</div><div class="stat-label">Touring</div></div>
        <div class="stat-item"><div class="stat-num">TRAP CN</div><div class="stat-label">Core Member</div></div>
      </div>
    </div>
    <div class="about-text">
      <div class="section-label">About</div>
      <h2 class="section-title">The Man<br>Behind<br>The Decks</h2>
      <p><strong>DJ Yida</strong> — Global Hip-Hop with a Chinese Flavor. A self-taught prodigy and Duke Kunshan University graduate, Yida blends <strong>DJing and MCing</strong> across Trap, Rage, Jersey Club, Afro, R&B, and Amapiano with a unique musical vision that crosses every border.</p>
      <p>A core member of <strong>TRAP CN</strong>, he has opened for J.I.D, Homixide Gang, Lil Tjay, Rich The Kid, 24KGoldn and more across China and the globe. His projects <strong>YIDA ON THE ROAD</strong> and <strong>YIDA & FRIENDS</strong> bring music, culture, and community together worldwide — from ComplexCon HK to Travis Scott's After Party in London.</p>
      <div class="about-tags">
        <span class="tag">Hip-Hop</span><span class="tag">Trap</span><span class="tag">Jersey Club</span><span class="tag">Rage</span><span class="tag">Afro</span><span class="tag">R&B</span><span class="tag">Amapiano</span><span class="tag">TRAP CN</span>
      </div>
    </div>
  </div>
</section>

<!-- EVENTS -->
<section id="events">
  <div class="events-inner">
    <div class="section-label">Schedule</div>
    <h2 class="section-title">Upcoming<br>Events</h2>
    <div class="event-card featured">
      <div class="event-date"><div class="event-day">03</div><div class="event-month">Apr 2026</div></div>
      <div class="event-info"><div class="event-name">Bad basement club</div><div class="event-meta"><span>📍 133 Cecil St, Singapore</span><span>🕙 10PM – 3AM</span><span>🎟 $22.05 - $40</span></div></div>
      <div class="event-actions"><span class="event-badge badge-hot">🔥 Selling Fast</span><a href="https://www.eventbrite.sg/e/cherry-ft-dj-yida-3rd-april-2026-tickets-1985988732761" target="_blank" rel="noopener noreferrer" class="event-btn">Get Tickets</a></div>
    </div>
    <div class="event-card">
      <div class="event-date"><div class="event-day">05</div><div class="event-month">May 2025</div></div>
      <div class="event-info"><div class="event-name">ROOFTOP SESSIONS VOL. 4</div><div class="event-meta"><span>📍 Sky Lounge, Midtown</span><span>🕙 8PM – 2AM</span><span>🎟 $20</span></div></div>
      <div class="event-actions"><a href="#contact" class="event-btn">Get Tickets</a></div>
    </div>
    <div class="event-card">
      <div class="event-date"><div class="event-day">19</div><div class="event-month">May 2025</div></div>
      <div class="event-info"><div class="event-name">CITY BLOCK BASH</div><div class="event-meta"><span>📍 Central Park Amphitheater</span><span>🕙 4PM – 10PM</span><span>🎟 Free Entry</span></div></div>
      <div class="event-actions"><span class="event-badge badge-free">Free</span><a href="#contact" class="event-btn">RSVP</a></div>
    </div>
    <div class="event-card">
      <div class="event-date"><div class="event-day">02</div><div class="event-month">Jun 2025</div></div>
      <div class="event-info"><div class="event-name">HEATWAVE FESTIVAL</div><div class="event-meta"><span>📍 Riverfront Grounds</span><span>🕙 12PM – 11PM</span><span>🎟 $60 – $120</span></div></div>
      <div class="event-actions"><a href="#contact" class="event-btn">Get Tickets</a></div>
    </div>
    <div class="event-card past">
      <div class="event-date"><div class="event-day">14</div><div class="event-month">Feb 2025</div></div>
      <div class="event-info"><div class="event-name">VALENTINES NIGHT TAKEOVER</div><div class="event-meta"><span>📍 Club Nova</span><span>🕙 9PM – 3AM</span><span>Sold Out</span></div></div>
      <div class="event-actions"><span class="event-badge badge-sold">Sold Out</span></div>
    </div>
    <div class="events-more"><a href="#contact" class="btn-outline">Request a Private Event</a></div>
  </div>
</section>

<!-- GALLERY -->
<section id="highlights">
  <div class="highlights-inner">
    <div class="section-label">Gallery</div>
    <h2 class="section-title">Event<br>Highlights</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-overlay"></div><div class="gallery-caption"><div class="gallery-caption-title">TrapCN Stage</div><div class="gallery-caption-sub">TrapCN × HXG × Undergrooves</div></div>
      </div>
      <div class="gallery-item">
        <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-overlay"></div><div class="gallery-caption"><div class="gallery-caption-title">Crowd Energy</div><div class="gallery-caption-sub">DJ Yida — Front Row Moment</div></div>
      </div>
      <div class="gallery-item">
        <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-overlay"></div><div class="gallery-caption"><div class="gallery-caption-title">Freak Out Festival</div><div class="gallery-caption-sub">Heineken Soundscape — Main Stage</div></div>
      </div>
      <div class="gallery-item">
        <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-overlay"></div><div class="gallery-caption"><div class="gallery-caption-title">TrapCN Performance</div><div class="gallery-caption-sub">On Stage with the Crowd</div></div>
      </div>
      <div class="gallery-item">
        <img src="data:image/jpeg;base64," style="width:100%;height:100%;object-fit:cover;">
        <div class="gallery-overlay"></div><div class="gallery-caption"><div class="gallery-caption-title">ComplexCon Hong Kong</div><div class="gallery-caption-sub">P&P Stage — 2025</div></div>
      </div>
    </div>
    <p class="gallery-upload-note">// Hover over photos to see event details //</p>
  </div>
</section>

<!-- MEDIA -->
<section id="media">
  <div class="media-inner">
    <div class="media-header">
      <div>
        <div class="section-label">Media</div>
        <h2 class="section-title" style="margin-bottom:0">Watch &<br>Listen</h2>
      </div>
      <a href="https://www.youtube.com/@djyida" target="_blank" class="btn-outline">All Videos ↗</a>
